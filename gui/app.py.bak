                    tk.Label(card, text=nl.get("subject_line", "")[:50],
                             font=get_font("sm"), fg=THEME.fg_dark, bg=THEME.bg_highlight).pack(side=tk.LEFT, padx=15)
                    tk.Label(card, text=f"{nl.get('story_count', 0)} stories",
                             font=get_font("xs"), fg=THEME.comment, bg=THEME.bg_highlight).pack(side=tk.RIGHT)
            
            # Close button
            tk.Button(popup, text="Close", font=get_font("md", "bold"),
                      bg=THEME.red, fg=THEME.fg, padx=20, pady=8,
                      relief=tk.FLAT, cursor="hand2",
                      command=popup.destroy).pack(pady=15)
                      
        except Exception as e:
            logger.error(f"Failed to show newsletter history: {e}")
            messagebox.showerror("Error", f"Failed to load newsletter history: {e}")
    
    def _show_crawler_popup(self):
        """Show web crawler configuration popup."""
        popup = tk.Toplevel(self.root)
        popup.title("🕷️ Web Crawler")
        popup.geometry("600x450")
        popup.configure(bg=THEME.bg)
        
        # Header
        header = tk.Frame(popup, bg=THEME.bg_dark, height=50)
        header.pack(fill=tk.X)
        header.pack_propagate(False)
        
        tk.Label(header, text="🕷️ WEB CRAWLER", font=get_font("lg", "bold"),
                 fg=THEME.purple, bg=THEME.bg_dark).pack(side=tk.LEFT, padx=20, pady=12)
        
        # Content
        content = tk.Frame(popup, bg=THEME.bg, padx=20, pady=20)
        content.pack(fill=tk.BOTH, expand=True)
        
        # URL input
        tk.Label(content, text="Seed URL:", font=get_font("sm", "bold"),
                 fg=THEME.fg, bg=THEME.bg).pack(anchor=tk.W)
        
        url_entry = tk.Entry(content, font=get_font("md"), bg=THEME.bg_visual, fg=THEME.fg,
                             insertbackground=THEME.purple, relief=tk.FLAT,
                             highlightthickness=2, highlightcolor=THEME.purple)
        url_entry.pack(fill=tk.X, pady=(5, 15), ipady=8)
        url_entry.insert(0, "https://techcrunch.com")
        
        # Options
        options_frame = tk.Frame(content, bg=THEME.bg)
        options_frame.pack(fill=tk.X, pady=10)
        
        tk.Label(options_frame, text="Max Depth:", font=get_font("sm"),
                 fg=THEME.fg_dark, bg=THEME.bg).pack(side=tk.LEFT)
        depth_var = tk.StringVar(value="2")
        depth_entry = tk.Entry(options_frame, font=get_font("sm"), width=5, 
                               textvariable=depth_var, bg=THEME.bg_visual, fg=THEME.fg)
        depth_entry.pack(side=tk.LEFT, padx=10)
        
        tk.Label(options_frame, text="Max Pages:", font=get_font("sm"),
                 fg=THEME.fg_dark, bg=THEME.bg).pack(side=tk.LEFT, padx=(20, 0))
        pages_var = tk.StringVar(value="20")
        pages_entry = tk.Entry(options_frame, font=get_font("sm"), width=5,
                               textvariable=pages_var, bg=THEME.bg_visual, fg=THEME.fg)
        pages_entry.pack(side=tk.LEFT, padx=10)
        
        # Status
        status_label = tk.Label(content, text="Configure and start crawling",
                                font=get_font("sm"), fg=THEME.fg_dark, bg=THEME.bg)
        status_label.pack(pady=15)
        
        # Results
        result_text = tk.Text(content, font=get_font("sm", mono=True),
                              bg=THEME.bg_visual, fg=THEME.fg, height=8, state=tk.DISABLED)
        result_text.pack(fill=tk.BOTH, expand=True, pady=10)
        
        async def run_crawl():
            try:
                from src.crawler import WebCrawler, CrawlConfig
                
                url = url_entry.get().strip()
                max_depth = int(depth_var.get())
                max_pages = int(pages_var.get())
                
                status_label.config(text=f"Crawling {url}...", fg=THEME.cyan)
                
                config = CrawlConfig(
                    max_depth=max_depth,
                    max_pages=max_pages,
                    article_only=True
                )
                crawler = WebCrawler(config)
                results = await crawler.crawl([url])
                
                stats = crawler.get_stats()
                
                status_label.config(text=f"✅ Crawl complete! {stats['successful_crawls']} pages found", fg=THEME.green)
                
                result_text.config(state=tk.NORMAL)
                result_text.delete(1.0, tk.END)
                result_text.insert(tk.END, f"Crawl Statistics:\n")
                result_text.insert(tk.END, f"  Pages visited: {stats['pages_visited']}\n")
                result_text.insert(tk.END, f"  Successful: {stats['successful_crawls']}\n")
                result_text.insert(tk.END, f"  Max depth: {stats['max_depth_reached']}\n\n")
                result_text.insert(tk.END, "Articles found:\n")
                for r in results[:10]:
                    if r.success:
                        result_text.insert(tk.END, f"  • {r.title[:60]}...\n")
                result_text.config(state=tk.DISABLED)
                
            except Exception as e:
                status_label.config(text=f"❌ Error: {str(e)[:50]}", fg=THEME.red)
        
        def start_crawl():
            self._async_runner.run_async(run_crawl())
        
        # Buttons
        btn_frame = tk.Frame(popup, bg=THEME.bg)
        btn_frame.pack(fill=tk.X, pady=15)
        
        tk.Button(btn_frame, text="🕷️ Start Crawl", font=get_font("md", "bold"),
                  bg=THEME.purple, fg=THEME.fg, padx=25, pady=10,
                  relief=tk.FLAT, cursor="hand2",
                  command=start_crawl).pack(side=tk.LEFT, padx=20)
        
        tk.Button(btn_frame, text="Close", font=get_font("md", "bold"),
                  bg=THEME.red, fg=THEME.fg, padx=20, pady=10,
                  relief=tk.FLAT, cursor="hand2",
                  command=popup.destroy).pack(side=tk.RIGHT, padx=20)


class DeveloperDashboard:
    """Developer dashboard for monitoring application internals - Tokyo Night themed."""
    
    def __init__(self, parent, orchestrator: TechNewsOrchestrator, async_runner: AsyncRunner):
        self.parent = parent
        self.orchestrator = orchestrator
        self.async_runner = async_runner
        
        self.window = tk.Toplevel(parent)
        self.window.title("🛠️ Developer Dashboard - Tech News Scraper")
        self.window.geometry("1150x800")
        self.window.configure(bg=THEME.bg)
        
        self._build_ui()
        
        # Subscribe to events
        self._subscribe_to_events()
        
        self._start_clock()
        self._start_stats_polling()  # NEW: Auto-refresh stats
        self._start_log_polling()    # NEW: Auto-refresh logs


    def _subscribe_to_events(self):
        """Subscribe to real-time events."""
        # Note: Handlers are async, so we use async_runner to wrap them if needed,
        # but here we need a bridge to Tkinter main thread.
        # Function to bridge async event to Tkinter queue
        
        async def on_stats(event: StatsUpdate):
            self.window.after(0, self._update_stats_ui, event)
            
        async def on_log(event: LogMessage):
            self.window.after(0, self._update_log_ui, event)
            
        event_bus.subscribe(EventType.STATS_UPDATE, on_stats)
        event_bus.subscribe(EventType.LOG_MESSAGE, on_log)

    def _start_clock(self):
        """Start the time update loop (only keeping this polling for clock)."""
        self._update_clock()
        
    def _update_clock(self):
        if not self.window.winfo_exists():
            return
        now = datetime.now().strftime("%H:%M:%S")
        self.time_label.config(text=f"🕒 {now} • LIVE")
        self.window.after(1000, self._update_clock)
    
    def _start_stats_polling(self):
        """Start auto-refresh polling for stats and cache."""
        self._refresh_all_stats()
    
    def _refresh_all_stats(self):
        """Refresh all stats from orchestrator."""
        if not self.window.winfo_exists():
            return
        
        try:
            # Get orchestrator stats
            stats = self.orchestrator._stats
            
            # Update performance labels
            if hasattr(self, 'perf_labels'):
                self.perf_labels['requests'].config(
                    text=str(stats.get('sources_scraped', 0) + stats.get('urls_analyzed', 0))
                )
                self.perf_labels['articles_found'].config(
                    text=str(stats.get('articles_scraped', 0))
                )
                self.perf_labels['queries_processed'].config(
                    text=str(stats.get('queries_processed', 0))
                )
                self.perf_labels['queries_rejected'].config(
                    text=str(stats.get('queries_rejected', 0))
                )
                self.perf_labels['urls_analyzed'].config(
                    text=str(stats.get('urls_analyzed', 0))
                )
            
            # Get realtime feeder stats
            if hasattr(self.orchestrator, '_realtime_feeder'):
                feeder_stats = self.orchestrator._realtime_feeder._stats
                refreshes = feeder_stats.get('refreshes', 0)
                fetch_errors = feeder_stats.get('fetch_errors', 0)
                if hasattr(self, 'perf_labels'):
                    self.perf_labels['successes'].config(
                        text=str(feeder_stats.get('articles_added', 0))
                    )
                    self.perf_labels['failures'].config(
                        text=str(fetch_errors)
                    )
            
            # Update cache stats
            self._refresh_cache_stats()
            
        except Exception as e:
            pass  # Silently ignore stats update errors
        
        # Schedule next refresh (2 seconds)
        self.window.after(2000, self._refresh_all_stats)
    
    def _refresh_cache_stats(self):
        """Refresh cache metrics from orchestrator."""
        if not hasattr(self, 'cache_labels'):
            return
            
        try:
            # Get HTTP cache stats (if available)
            if hasattr(self.orchestrator, '_realtime_feeder'):
                cache = self.orchestrator._realtime_feeder._response_cache
                self.cache_labels['Size'].config(text=str(len(cache._cache)))
                self.cache_labels['Max Size'].config(text=str(cache._max_responses))
                self.cache_labels['Hits'].config(text=str(cache._hits))
                self.cache_labels['Misses'].config(text=str(cache._misses))
                total = cache._hits + cache._misses
                hit_rate = (cache._hits / total * 100) if total > 0 else 0
                self.cache_labels['Hit Rate'].config(text=f"{hit_rate:.1f}%")
            
            # Update bloom filter stats
            if hasattr(self.orchestrator, '_url_dedup'):
                bloom = self.orchestrator._url_dedup
                self.bloom_labels['Items'].config(text=str(bloom._item_count))
                size_kb = len(bloom._bit_array) / 8 / 1024
                self.bloom_labels['Size (KB)'].config(text=f"{size_kb:.1f}")
                self.bloom_labels['False Positive Rate'].config(
                    text=f"{bloom._fp_rate * 100:.2f}%"
                )
        except Exception:
            pass  # Silently ignore cache update errors
    
    def _start_log_polling(self):
        """Start polling for new log entries from file."""
        self._last_log_position = 0
        self._poll_logs()
    
    def _poll_logs(self):
        """Poll log file for new entries."""
        if not self.window.winfo_exists():
            return
        
        try:
            log_file = PROJECT_ROOT / "logs" / "scraper.log"
            if log_file.exists():
                with open(log_file, 'r') as f:
                    f.seek(self._last_log_position)
                    new_content = f.read()
                    if new_content:
                        self.log_text.config(state=tk.NORMAL)
                        self.log_text.insert(tk.END, new_content)
                        self.log_text.config(state=tk.DISABLED)
                        self.log_text.see(tk.END)
                    self._last_log_position = f.tell()
        except Exception:
            pass  # Silently ignore log polling errors
        
        # Schedule next poll (500ms)
        self.window.after(500, self._poll_logs)
        
    def _update_stats_ui(self, event: StatsUpdate):
        """Update stats UI from event data."""
        if not self.window.winfo_exists():
            return
            
        # Update counters
        self.perf_labels['requests'].config(text=str(event.total_requests))
        self.perf_labels['articles_found'].config(text=str(event.total_articles))
        # self.perf_labels['successes'].config(text=f"{event.success_rate:.1%}")    
    def _update_log_ui(self, event: LogMessage):
        """Update logs UI from event data."""
        if not self.window.winfo_exists():
            return
            
        # Format: [HH:MM:SS] [LEVEL] Source: Message
        timestamp = event.timestamp.strftime("%H:%M:%S")
        # Color coding
        color = THEME.fg
        if event.level == "ERROR":
            color = THEME.red
        elif event.level == "WARNING":
            color = THEME.orange
        elif event.level == "DEBUG":
            color = THEME.comment
            
        self.log_text.configure(state='normal')
        self.log_text.insert(tk.END, f"[{timestamp}] ", "timestamp")
        self.log_text.insert(tk.END, f"[{event.level}] ", event.level)
        self.log_text.insert(tk.END, f"{event.message}\n", "message")
        self.log_text.configure(state='disabled')
        self.log_text.see(tk.END)
    
    def _build_ui(self):
        # Header
        header = tk.Frame(self.window, bg=THEME.bg_dark, height=55)
        header.pack(fill=tk.X)
        header.pack_propagate(False)
        
        tk.Frame(header, bg=THEME.purple, height=3).pack(fill=tk.X, side=tk.TOP)
        
        header_inner = tk.Frame(header, bg=THEME.bg_dark)
        header_inner.pack(fill=tk.BOTH, expand=True, padx=20)
        
        tk.Label(header_inner, text="🛠️", font=get_font("xl"),
                 fg=THEME.purple, bg=THEME.bg_dark).pack(side=tk.LEFT, pady=10)
        tk.Label(header_inner, text="DEVELOPER DASHBOARD", font=get_font("lg", "bold"),
                 fg=THEME.green, bg=THEME.bg_dark).pack(side=tk.LEFT, padx=(8, 0), pady=10)
        
        self.time_label = tk.Label(header_inner, text="", font=get_font("sm", mono=True),
                                    fg=THEME.comment, bg=THEME.bg_dark)
        self.time_label.pack(side=tk.RIGHT, pady=10)
        
        # Live Monitor quick-toggle button
        self.live_monitor_btn = tk.Button(header_inner, text="⚡ Live Monitor",
                                          font=get_font("sm", "bold"), bg=THEME.cyan,
                                          fg=THEME.black, padx=15, pady=4,
                                          relief=tk.FLAT, cursor="hand2",
                                          command=self._toggle_live_monitor)
        self.live_monitor_btn.pack(side=tk.RIGHT, padx=15, pady=8)
        
        # Main content with tabs
        style = ttk.Style()
        style.configure('Dev.TNotebook', background=THEME.bg, borderwidth=0)
        style.configure('Dev.TNotebook.Tab', background=THEME.bg_highlight, 
                       foreground=THEME.fg_dark, padding=[14, 8],
                       font=get_font("sm", "bold"))
        style.map('Dev.TNotebook.Tab', 
                 background=[("selected", THEME.bg_visual)],
                 foreground=[("selected", THEME.green)])
        
        self.notebook = ttk.Notebook(self.window, style='Dev.TNotebook')
        self.notebook.pack(fill=tk.BOTH, expand=True, padx=12, pady=12)
        
        # Stats tab
        stats_frame = tk.Frame(self.notebook, bg=THEME.bg)
        self.notebook.add(stats_frame, text="📊 Performance")
        self._build_stats_tab(stats_frame)
        
        # Cache tab
        cache_frame = tk.Frame(self.notebook, bg=THEME.bg)
        self.notebook.add(cache_frame, text="💾 Cache")
        self._build_cache_tab(cache_frame)
        
        # Logs tab
        logs_frame = tk.Frame(self.notebook, bg=THEME.bg)
        self.notebook.add(logs_frame, text="📋 Logs")
        self._build_logs_tab(logs_frame)
        
        # Workflow tab
        workflow_frame = tk.Frame(self.notebook, bg=THEME.bg)
        self.notebook.add(workflow_frame, text="🔄 Workflow")
        self._build_workflow_tab(workflow_frame)
        
        # Live Monitor tab (new)
        self.live_monitor_frame = tk.Frame(self.notebook, bg=THEME.bg)
        self.notebook.add(self.live_monitor_frame, text="⚡ Live Monitor")
        self._build_live_monitor_tab(self.live_monitor_frame)
    
    def _build_stats_tab(self, parent):
        # Grid of stats
        grid = tk.Frame(parent, bg=THEME.bg, padx=20, pady=20)
        grid.pack(fill=tk.BOTH, expand=True)
        
        self.perf_labels = {}
        
        stats = [
            ('Total Requests', 'requests', THEME.cyan),
            ('Successful', 'successes', THEME.green),
            ('Failed', 'failures', THEME.red),
            ('Cache Hits', 'cached_hits', THEME.yellow),
            ('Articles Found', 'articles_found', THEME.blue),
            ('Queries Processed', 'queries_processed', THEME.purple),
            ('Queries Rejected', 'queries_rejected', THEME.orange),
            ('URLs Analyzed', 'urls_analyzed', THEME.magenta),
        ]
        
        for i, (label, key, color) in enumerate(stats):
            row, col = i // 4, i % 4
            
            frame = tk.Frame(grid, bg=THEME.bg_highlight, padx=25, pady=18)
            frame.grid(row=row, column=col, padx=10, pady=10, sticky='nsew')
            
            tk.Label(frame, text=label, font=get_font("sm"),
                     fg=THEME.comment, bg=THEME.bg_highlight).pack()
            self.perf_labels[key] = tk.Label(frame, text="0", font=get_font("3xl", "bold", mono=True),
                                              fg=color, bg=THEME.bg_highlight)
            self.perf_labels[key].pack()
        
        for i in range(4):
            grid.columnconfigure(i, weight=1)
    
    def _build_cache_tab(self, parent):
        content = tk.Frame(parent, bg=THEME.bg, padx=25, pady=25)
        content.pack(fill=tk.BOTH, expand=True)
        
        # HTTP Cache Section
        tk.Label(content, text="HTTP Response Cache", font=get_font("lg", "bold"),
                 fg=THEME.cyan, bg=THEME.bg).pack(anchor=tk.W, pady=(0, 15))
        
        self.cache_labels = {}
        cache_items = [
            ('Size', THEME.green),
            ('Max Size', THEME.fg_dark),
            ('Hits', THEME.green),
            ('Misses', THEME.red),
            ('Hit Rate', THEME.yellow)
        ]
        for label, color in cache_items:
            frame = tk.Frame(content, bg=THEME.bg_highlight, padx=18, pady=12)
            frame.pack(fill=tk.X, pady=4)
            tk.Label(frame, text=f"{label}:", font=get_font("sm"),
                     fg=THEME.comment, bg=THEME.bg_highlight).pack(side=tk.LEFT)
            self.cache_labels[label] = tk.Label(frame, text="--", font=get_font("sm", "bold", mono=True),
                                                 fg=color, bg=THEME.bg_highlight)
            self.cache_labels[label].pack(side=tk.RIGHT)
        
        # Bloom Filter Section
        tk.Label(content, text="URL Deduplicator (Bloom Filter)", font=get_font("lg", "bold"),
                 fg=THEME.orange, bg=THEME.bg).pack(anchor=tk.W, pady=(30, 15))
        
        self.bloom_labels = {}
        bloom_items = [
            ('Items', THEME.cyan),
            ('Size (KB)', THEME.purple),
            ('False Positive Rate', THEME.yellow)
        ]
        for label, color in bloom_items:
            frame = tk.Frame(content, bg=THEME.bg_highlight, padx=18, pady=12)
            frame.pack(fill=tk.X, pady=4)
            tk.Label(frame, text=f"{label}:", font=get_font("sm"),
                     fg=THEME.comment, bg=THEME.bg_highlight).pack(side=tk.LEFT)
            self.bloom_labels[label] = tk.Label(frame, text="--", font=get_font("sm", "bold", mono=True),
                                                 fg=color, bg=THEME.bg_highlight)
            self.bloom_labels[label].pack(side=tk.RIGHT)
    
    def _build_logs_tab(self, parent):
        content = tk.Frame(parent, bg=THEME.bg, padx=25, pady=25)
        content.pack(fill=tk.BOTH, expand=True)
        
        header = tk.Frame(content, bg=THEME.bg)
        header.pack(fill=tk.X, pady=(0, 12))
        
        tk.Label(header, text="📋", font=get_font("lg"),
                 fg=THEME.green, bg=THEME.bg).pack(side=tk.LEFT)
        tk.Label(header, text="Application Logs", font=get_font("lg", "bold"),
                 fg=THEME.green, bg=THEME.bg).pack(side=tk.LEFT, padx=(8, 0))
        tk.Label(header, text="(scraper.log)", font=get_font("sm"),
                 fg=THEME.comment, bg=THEME.bg).pack(side=tk.LEFT, padx=(10, 0))
        
        self.log_text = scrolledtext.ScrolledText(content, font=get_font("sm", mono=True),
                                                    bg=THEME.bg_dark, fg=THEME.green,
                                                    wrap=tk.WORD, height=22, relief=tk.FLAT,
                                                    insertbackground=THEME.cyan)
        self.log_text.pack(fill=tk.BOTH, expand=True)
        
        btn_frame = tk.Frame(content, bg=THEME.bg)
        btn_frame.pack(fill=tk.X, pady=(12, 0))
        
        tk.Button(btn_frame, text="🔄 Refresh Logs", font=get_font("sm", "bold"),
                  bg=THEME.blue, fg=THEME.fg, activebackground=THEME.bright_blue,
                  padx=18, pady=8, relief=tk.FLAT, cursor='hand2',
                  command=self._load_logs).pack(side=tk.LEFT)
                  
        tk.Button(btn_frame, text="🗑️ Clear Logs", font=get_font("sm", "bold"),
                  bg=THEME.red, fg=THEME.fg, activebackground=THEME.bright_red,
                  padx=18, pady=8, relief=tk.FLAT, cursor='hand2',
                  command=self._clear_logs).pack(side=tk.LEFT, padx=10)
        
        self._load_logs()
        
    def _clear_logs(self):
        """Clear logs from UI and file."""
        if messagebox.askyesno("Clear Logs", "Are you sure you want to clear all system logs?"):
            # Clear UI
            self.log_text.config(state=tk.NORMAL)
            self.log_text.delete(1.0, tk.END)
            self.log_text.config(state=tk.DISABLED)
            
            # Clear file
            try:
                log_file = PROJECT_ROOT / "logs" / "scraper.log"
                with open(log_file, 'w') as f:
                    f.truncate(0)
                logger.info("Logs cleared by developer")
            except Exception as e:
                logger.error(f"Failed to clear log file: {e}")
    
    def _build_workflow_tab(self, parent):
        content = tk.Frame(parent, bg=THEME.bg, padx=25, pady=25)
        content.pack(fill=tk.BOTH, expand=True)
        
        header = tk.Frame(content, bg=THEME.bg)
        header.pack(fill=tk.X, pady=(0, 15))
        
        tk.Label(header, text="🔄", font=get_font("lg"),
                 fg=THEME.magenta, bg=THEME.bg).pack(side=tk.LEFT)
        tk.Label(header, text="Application Workflow", font=get_font("lg", "bold"),
                 fg=THEME.magenta, bg=THEME.bg).pack(side=tk.LEFT, padx=(8, 0))
        
        workflow = """ """
        
        text = scrolledtext.ScrolledText(content, font=get_font("md", mono=True),
                                          bg=THEME.bg_dark, fg=THEME.cyan,
                                          wrap=tk.NONE, height=28, relief=tk.FLAT)
        text.pack(fill=tk.BOTH, expand=True)
        text.insert(tk.END, workflow)
        text.config(state=tk.DISABLED)
    
    def _load_logs(self):
        self.log_text.config(state=tk.NORMAL)
        self.log_text.delete(1.0, tk.END)
        
        log_file = PROJECT_ROOT / "logs" / "scraper.log"
        if log_file.exists():
            try:
                with open(log_file, 'r') as f:
                    lines = f.readlines()[-100:]  # Last 100 lines
                    self.log_text.insert(tk.END, "".join(lines))
            except Exception as e:
                self.log_text.insert(tk.END, f"Error reading logs: {e}")
        else:
            self.log_text.insert(tk.END, "No log file found.")
        
        self.log_text.config(state=tk.DISABLED)
        self.log_text.see(tk.END)
    
    def _update_data(self):
        now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        self.time_label.config(text=f"🕐 {now}")
        
        if not self.orchestrator:
            return
        
        # Update performance stats
        stats = self.orchestrator.stats
        scraper_stats = stats.get('scraper_stats', {})
        
        for key in self.perf_labels:
            value = scraper_stats.get(key, stats.get(key, 0))
            self.perf_labels[key].config(text=str(value))
        
        # Update cache stats
        cache_stats = scraper_stats.get('cache_stats', {})
        self.cache_labels['Size'].config(text=str(cache_stats.get('size', 0)))
        self.cache_labels['Max Size'].config(text=str(cache_stats.get('max_size', 0)))
        self.cache_labels['Hits'].config(text=str(cache_stats.get('hits', 0)))
        self.cache_labels['Misses'].config(text=str(cache_stats.get('misses', 0)))
        self.cache_labels['Hit Rate'].config(text=f"{cache_stats.get('hit_rate', 0):.1%}")
        
        # Update bloom filter stats
        dedup_stats = scraper_stats.get('dedup_stats', {})
        self.bloom_labels['Items'].config(text=str(dedup_stats.get('count', 0)))
        self.bloom_labels['Size (KB)'].config(text=f"{dedup_stats.get('size_kb', 0):.2f}")
        self.bloom_labels['False Positive Rate'].config(text=f"{dedup_stats.get('false_positive_rate', 0):.4f}")
    
    def _start_refresh(self):
        self._update_data()
        self.window.after(2000, self._start_refresh)

    def _toggle_live_monitor(self):
        """Switch to the Live Monitor tab."""
        # Find the Live Monitor tab index (it's the last tab, index 4)
        self.notebook.select(4)

    def _build_live_monitor_tab(self, parent):
        """Build the Live Monitor tab with process tracking and activity log."""
        # Initialize tracking
        self._lm_log_buffer_idx = 0
        self._lm_status_items = {}
        self._lm_reset_timers = {}
        self._lm_spinner_chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        self._lm_spinner_idx = 0
        
        # Main container
        main_frame = tk.Frame(parent, bg=THEME.bg)
        main_frame.pack(fill=tk.BOTH, expand=True, padx=20, pady=20)
        
        # Left column: Process Status
        left_col = tk.Frame(main_frame, bg=THEME.bg, width=300)
        left_col.pack(side=tk.LEFT, fill=tk.Y, padx=(0, 20))
        left_col.pack_propagate(False)
        
        # Process Status Card
        proc_card = tk.Frame(left_col, bg=THEME.bg_dark, padx=20, pady=15)
        proc_card.pack(fill=tk.X)
        
        tk.Label(proc_card, text="⚡ SYSTEM PROCESSES", font=get_font("sm", "bold"),
                 fg=THEME.cyan, bg=THEME.bg_dark).pack(anchor=tk.W, pady=(0, 15))
        
        # Status items (same as LiveLogPanel)
        process_defs = [
            ("system", "⚙️ System", "Initializing..."),
            ("feed", "📡 Live Feed", "Waiting"),
            ("bypass", "🔓 Bypass", "Standby"),
            ("scraper", "🌐 Scraper", "Idle"),
            ("orch", "🔄 Processor", "Idle"),
        ]
        
        for key, label, initial in process_defs:
            self._add_lm_status_item(proc_card, key, label, initial)
        
        # Right column: Activity Log
        right_col = tk.Frame(main_frame, bg=THEME.bg)
        right_col.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        
        # Activity Log Card
        log_card = tk.Frame(right_col, bg=THEME.bg_dark, padx=20, pady=15)
        log_card.pack(fill=tk.BOTH, expand=True)
        
        log_header = tk.Frame(log_card, bg=THEME.bg_dark)
        log_header.pack(fill=tk.X)
        
        tk.Label(log_header, text="📋 ACTIVITY LOG", font=get_font("sm", "bold"),
                 fg=THEME.cyan, bg=THEME.bg_dark).pack(side=tk.LEFT)
        
        # Clear button
        clear_btn = tk.Button(log_header, text="Clear", font=get_font("xs"),
                              bg=THEME.bg_highlight, fg=THEME.fg_dark,
                              relief=tk.FLAT, cursor="hand2",
                              command=self._lm_clear_logs)
        clear_btn.pack(side=tk.RIGHT)
        
        # Log text area
        self._lm_log_text = scrolledtext.ScrolledText(
            log_card, font=get_font("xs", mono=True),
            bg="#0d0d14", fg=THEME.fg,
            wrap=tk.WORD, height=25, relief=tk.FLAT,
            highlightthickness=1, highlightbackground=THEME.bg_highlight,
            insertbackground=THEME.cyan
        )
        self._lm_log_text.pack(fill=tk.BOTH, expand=True, pady=(15, 0))
        self._lm_log_text.configure(state='disabled')
        
        # Color tags
        self._lm_log_text.tag_config("INFO", foreground=THEME.fg)
        self._lm_log_text.tag_config("WARNING", foreground=THEME.orange)
        self._lm_log_text.tag_config("ERROR", foreground=THEME.red)
        self._lm_log_text.tag_config("SUCCESS", foreground=THEME.green)
        self._lm_log_text.tag_config("ACTION", foreground=THEME.cyan)
        self._lm_log_text.tag_config("timestamp", foreground="#565f89")
        self._lm_log_text.tag_config("component", foreground=THEME.magenta)
        
        # Start polling
        self._lm_poll_log_buffer()
        self._lm_animate_spinner()

    def _add_lm_status_item(self, parent, key, label, initial):
        """Add a status item to the Live Monitor."""
        frame = tk.Frame(parent, bg=THEME.bg_dark)
        frame.pack(fill=tk.X, pady=4)
        
        icon = tk.Label(frame, text="●", font=("Menlo", 10),
                        fg=THEME.comment, bg=THEME.bg_dark, width=2)
        icon.pack(side=tk.LEFT)
        
        tk.Label(frame, text=label, font=get_font("sm"),
                 fg=THEME.fg, bg=THEME.bg_dark).pack(side=tk.LEFT, padx=8)
        
        state_lbl = tk.Label(frame, text=initial, font=get_font("xs"),
                             fg=THEME.comment, bg=THEME.bg_dark)
        state_lbl.pack(side=tk.RIGHT)
        
        self._lm_status_items[key] = {
            'icon': icon,
            'state_lbl': state_lbl,
            'active': False
        }

    def _lm_update_status(self, key, state, active=False, auto_reset_ms=None):
        """Update a status indicator in Live Monitor."""
        if key not in self._lm_status_items:
            return
        try:
            item = self._lm_status_items[key]
            item['state_lbl'].config(text=state)
            item['active'] = active
            
            if active:
                item['state_lbl'].config(fg=THEME.cyan)
                item['icon'].config(fg=THEME.cyan)
            else:
                item['state_lbl'].config(fg=THEME.comment)
                item['icon'].config(text="●", fg=THEME.comment)
            
            if key in self._lm_reset_timers:
                try:
                    self.window.after_cancel(self._lm_reset_timers[key])
                except Exception:
                    pass
            
            if auto_reset_ms and active:
                self._lm_reset_timers[key] = self.window.after(
                    auto_reset_ms, 
                    lambda: self._lm_update_status(key, "Idle", False)
                )
        except Exception:
            pass

    def _lm_poll_log_buffer(self):
        """Poll the global log buffer for new messages."""
        try:
            if not self.window.winfo_exists():
                return
            
            with _log_buffer_lock:
                buffer_len = len(_log_buffer)
                if self._lm_log_buffer_idx < buffer_len:
                    new_messages = _log_buffer[self._lm_log_buffer_idx:buffer_len]
                    self._lm_log_buffer_idx = buffer_len
                else:
                    new_messages = []
            
            for log_msg in new_messages[:15]:
                self._lm_add_log_entry(log_msg)
                self._lm_update_indicators(log_msg.message.lower())
            
            self.window.after(100, self._lm_poll_log_buffer)
        except Exception:
            pass

    def _lm_add_log_entry(self, log_msg):
        """Add log entry to the Live Monitor."""
        try:
            if not self.window.winfo_exists():
                return
            
            self._lm_log_text.configure(state='normal')
            
            ts = log_msg.timestamp.strftime("%H:%M:%S")
            self._lm_log_text.insert(tk.END, f"{ts} ", "timestamp")
            
            comp_short = log_msg.component.split('.')[-1][:12].ljust(12) if log_msg.component else "system".ljust(12)
            self._lm_log_text.insert(tk.END, f"{comp_short} ", "component")
            
            # Determine tag
            tag = log_msg.level
            msg_lower = log_msg.message.lower()
            if "success" in msg_lower or "complete" in msg_lower:
                tag = "SUCCESS"
            elif "bypass" in msg_lower or "analyzing" in msg_lower:
                tag = "ACTION"
            
            display_msg = log_msg.message[:100] + "..." if len(log_msg.message) > 100 else log_msg.message
            self._lm_log_text.insert(tk.END, f"{display_msg}\n", tag)
            
            self._lm_log_text.configure(state='disabled')
            self._lm_log_text.see(tk.END)
        except Exception:
            pass

    def _lm_update_indicators(self, msg_lower):
        """Update status indicators based on log content."""
        state_patterns = {
            "eventbus started": ("system", "Event bus ready", True),
            "database schema initialized": ("system", "DB initialized", True),
            "loaded": ("system", "Data loaded", True),
            "orchestrator initialized": ("system", "Ready", True),
            "realtimenewsfeeder started": ("feed", "Active", True),
            "refreshing real-time": ("feed", "Refreshing...", True),
            "refresh complete": ("feed", "Monitoring", True),
            "attempting smart bypass": ("bypass", "Initiating...", True),
            "bypass successful": ("bypass", "Success ✓", True),
            "scraping source": ("scraper", "Fetching...", True),
            "new article": ("orch", "New Article", True),
            "analyzing url": ("orch", "Analyzing...", True),
        }
        
        for pattern, (key, state, active) in state_patterns.items():
            if pattern in msg_lower:
                reset_ms = 3000 if key in ("orch", "bypass") else None
                self._lm_update_status(key, state, active, reset_ms)
                return

    def _lm_clear_logs(self):
        """Clear the Live Monitor log."""
        try:
            self._lm_log_text.configure(state='normal')
            self._lm_log_text.delete("1.0", tk.END)
            self._lm_log_text.configure(state='disabled')
        except Exception:
            pass

    def _lm_animate_spinner(self):
        """Animate spinners for active processes."""
        try:
            if not self.window.winfo_exists():
                return
            
            char = self._lm_spinner_chars[self._lm_spinner_idx]
            self._lm_spinner_idx = (self._lm_spinner_idx + 1) % len(self._lm_spinner_chars)
            
            for key, item in self._lm_status_items.items():
                if item['active']:
                    item['icon'].config(text=char, fg=THEME.cyan)
            
            self.window.after(100, self._lm_animate_spinner)
        except Exception:
            pass


def main():
    root = tk.Tk()
    app = TechNewsGUI(root)
    root.protocol("WM_DELETE_WINDOW", app.on_close)
    root.mainloop()


if __name__ == "__main__":
    main()