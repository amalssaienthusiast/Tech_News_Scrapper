                     fg=THEME.green, bg=THEME.bg_dark).pack(side=tk.LEFT, padx=20, pady=12)
            tk.Label(header, text=f"{len(newsletters)} editions", font=get_font("sm"),
                     fg=THEME.comment, bg=THEME.bg_dark).pack(side=tk.RIGHT, padx=20, pady=12)
            
