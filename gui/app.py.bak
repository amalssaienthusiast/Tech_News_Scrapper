                 font=get_font("sm"), fg=THEME.fg_dark, bg=THEME.bg,
                 justify=tk.LEFT).pack(anchor=tk.W, pady=(0, 20))
        
        # Channel cards
        channels = [
            {
                "name": "In-App Notifications",
                "icon": "🖥️",
                "status": "Always Enabled",
                "enabled": True,
                "configured": True,
                "description": "Alerts appear in the GUI. No setup required.",
