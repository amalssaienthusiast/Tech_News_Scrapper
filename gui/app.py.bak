            tk.Label(header_row, text=ch["name"], font=get_font("md", "bold"),
                     fg=THEME.fg, bg=THEME.bg_highlight).pack(side=tk.LEFT, padx=(10, 0))
            
            # Status badge
            status_color = THEME.green if ch["configured"] else THEME.comment
