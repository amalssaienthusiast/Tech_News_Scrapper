# Required for basic functionality
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional - for AI features
GEMINI_API_KEY=
LLM_PROVIDER=hybrid
LLM_MODEL=gemini-1.5-flash

# Optional - for additional sources
NEWSAPI_KEY=
BING_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# Optional - for notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# API security and CORS
API_ALLOW_ANONYMOUS=false
API_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Database (defaults to SQLite if unset by app logic)
# DATABASE_URL=postgresql://user:pass@localhost/technews

# Redis (optional, for real-time features)
REDIS_URL=redis://localhost:6379/0
